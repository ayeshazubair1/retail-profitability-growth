      </column>
      <column caption='Margin opportunity' datatype='real' datatype-customized='true' name='[Calculation_0362640675774465]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_1708576922443777] &lt; MIN([Profit Margin % (copy)_0362640693387267])&#10;THEN&#10;(MIN([Profit Margin % (copy)_0362640693387267]) - [Calculation_1708576922443777])&#10;* [Calculation_2324235123474434]&#10;ELSE&#10;0&#10;END' />
      </column>
      <column caption='YOY Rank' datatype='integer' name='[Calculation_0362640770793482]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK_DENSE([Calculation_2324235290595338], &apos;desc&apos;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Total Margin Opportunity' datatype='real' name='[Calculation_0362640778928142]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_SUM([Calculation_0362640675774465])'>
          <table-calc ordering-field='[federated.0qz5sg01ofaeu01g3yncl0ouuz5w].[store_name]' ordering-type='Field' />
        </calculation>
      </column>
      <column caption='KPI Display Filter' datatype='boolean' name='[Calculation_0895560519696384]' role='measure' type='nominal'>
        <calculation class='tableau' formula='FIRST() = 0'>
          <table-calc ordering-field='[federated.0qz5sg01ofaeu01g3yncl0ouuz5w].[store_name]' ordering-type='Field' />
        </calculation>
      </column>
      <column caption='Gross Profit' datatype='real' name='[Calculation_1708576905101312]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_2324235123474434] - SUM([production_cost] * [quantity])' />
      </column>
      <column caption='Profit Margin %' datatype='real' name='[Calculation_1708576922443777]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1708576905101312]/[Calculation_2324235123474434]' />
      </column>
      <column caption='Revenue 2023' datatype='real' name='[Calculation_1708576924856322]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF YEAR([date]) = 2023 THEN [line_total] END)' />
      </column>
      <column caption='Revenue 2024' datatype='real' name='[Calculation_1708576931004419]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF YEAR([date]) = 2024 THEN [line_total] END)' />
      </column>
      <column caption='Top 3 Revenue Lable' datatype='real' name='[Calculation_1725279871000576]' role='measure' type='quantitative'>
