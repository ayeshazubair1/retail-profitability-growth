      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.0qz5sg01ofaeu01g3yncl0ouuz5w].[usr:Calculation_1708576922443777:qk]&quot;' value='Profit Margin' />
